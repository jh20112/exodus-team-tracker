generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TeamMember {
  id    String @id @default(cuid())
  name  String @unique
  color String
  cards    WeeklyCard[]
  projects Project[]
}

model WeeklyCard {
  id              String     @id @default(cuid())
  memberId        String
  member          TeamMember @relation(fields: [memberId], references: [id])
  weekStart       DateTime

  // Monday fields
  goalOfWeek      String?
  supportRequest  String?
  generalQuestions String?
  mondayCompleted Boolean    @default(false)

  // Friday fields
  rose            String?
  thorn           String?
  curiousMoment   String?
  proudOf         String?
  couldImprove    String?

  // Friday metrics (1-5 scale)
  metricEnergy         Int?
  metricGoalCompletion Int?
  metricMood           Int?
  metricCollaboration  Int?

  fridayCompleted Boolean    @default(false)

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([memberId, weekStart])
}

model Project {
  id          String          @id @default(cuid())
  memberId    String
  member      TeamMember      @relation(fields: [memberId], references: [id])
  name        String
  description String?
  color       String?
  posX        Float           @default(0.5)
  posY        Float           @default(0.5)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  items       ChecklistItem[]
  linksFrom   ProjectLink[]   @relation("linkFrom")
  linksTo     ProjectLink[]   @relation("linkTo")
}

model ChecklistItem {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  text      String
  completed Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectLink {
  id          String  @id @default(cuid())
  fromId      String
  toId        String
  description String?
  from        Project @relation("linkFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to          Project @relation("linkTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
}
