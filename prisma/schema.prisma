generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TeamMember {
  id    String @id @default(cuid())
  name  String @unique
  color String
  cards WeeklyCard[]
}

model WeeklyCard {
  id              String     @id @default(cuid())
  memberId        String
  member          TeamMember @relation(fields: [memberId], references: [id])
  weekStart       DateTime

  // Monday fields
  goalOfWeek      String?
  supportRequest  String?
  generalQuestions String?
  mondayCompleted Boolean    @default(false)

  // Friday fields
  rose            String?
  thorn           String?
  curiousMoment   String?
  proudOf         String?
  couldImprove    String?

  // Friday metrics (1-5 scale)
  metricEnergy         Int?
  metricGoalCompletion Int?
  metricMood           Int?
  metricCollaboration  Int?

  fridayCompleted Boolean    @default(false)

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([memberId, weekStart])
}
